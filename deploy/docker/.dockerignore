# ================================
# Docker 构建忽略文件
# 以下文件/目录不会被复制进 Docker 镜像
# ================================

# 版本控制
.git
.gitignore

# 环境配置（敏感数据！绝不打包进镜像）
.env
.env.*
!.env.example

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.ruff_cache/

# 虚拟环境
venv/
.venv/
env/
.env_backup/

# 测试文件
tests/
*.test.py

# 文档
docs/
*.md
!requirements.txt

# 数据目录（本地开发数据）
data/

# 部署脚本（不需要打包进镜像）
deploy/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# 日志
logs/
*.log

# 系统文件
.DS_Store
Thumbs.db

# CI/CD
.github/
.gitlab-ci.yml

# 其他开发工具
Makefile
*.sh
pyproject.toml
alembic.ini  # alembic.ini 在 runtime 阶段单独复制