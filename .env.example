# PUDIWIND Amazon operations AI system
# Copy this file to .env and fill in real values before running sync or deployment.

# Database
DATABASE_URL=postgresql://app_user:your_password@localhost:5432/amazon_ai

# Backend service
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DRY_RUN=false

# Web console authentication
# Format: username:bcrypt_hash:role,username2:bcrypt_hash2:role2
# Generate hash:
# python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
WEB_USERS=
JWT_SECRET=
JWT_ACCESS_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7

# OpenAI / LLM, optional for Phase 1 dashboard and ads management
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
MAX_DAILY_LLM_COST_USD=50.0

# Feishu, optional
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFY_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_TEST_CHAT_ID=

# Seller Sprite, optional
SELLER_SPRITE_API_KEY=
SELLER_SPRITE_MCP_ENDPOINT=https://mcp.sellersprite.com/mcp
SELLER_SPRITE_USE_MOCK=true

# Amazon Ads API, required for Phase 1 ads sync and real write operations
# Region values: NA, EU, FE
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
AMAZON_ADS_PROFILE_ID=
AMAZON_ADS_REGION=NA

# Amazon SP-API, required for Phase 1 sales sync
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_APP_ID=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER

# Google Trends, optional
GOOGLE_TRENDS_ENABLED=false
GOOGLE_TRENDS_API_KEY=
