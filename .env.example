# ================================
# PUDIWIND AI运营系统 环境变量配置
# 复制此文件为 .env，并填入真实值
# ================================

# 数据库连接（不要暴露此字符串给任何人）
DATABASE_URL=postgresql://app_user:your_password@localhost:5432/amazon_ai

# OpenAI API密钥（从 https://platform.openai.com/api-keys 获取）
OPENAI_API_KEY=sk-your-openai-key-here
# 默认模型（gpt-4o-mini更便宜，gpt-4o更智能）
OPENAI_MODEL=gpt-4o-mini

# Anthropic API密钥（可选，从 https://console.anthropic.com/ 获取）
ANTHROPIC_API_KEY=

# 飞书配置（从飞书开放平台 https://open.feishu.cn/ 获取）
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_VERIFY_TOKEN=your_verify_token_here
FEISHU_ENCRYPT_KEY=your_encrypt_key_here
# 测试飞书群的chat_id（用于发送测试消息）
FEISHU_TEST_CHAT_ID=oc_your_chat_id_here

# 卖家精灵API密钥（从卖家精灵账号获取）
SELLER_SPRITE_API_KEY=your_seller_sprite_key_here
# 是否使用Mock数据（true=使用假数据，false=使用真实API）
SELLER_SPRITE_USE_MOCK=true

# LLM每日费用上限（美元，超过此值停止调用）
MAX_DAILY_LLM_COST_USD=50.0

# 系统模式（true=只分析不执行，false=正常执行）
DRY_RUN=false

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 亚马逊SP-API（Phase 2使用，现在可以留空）
AMAZON_SP_API_ACCESS_KEY=
AMAZON_SP_API_SECRET_KEY=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
